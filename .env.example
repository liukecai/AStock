APP_ENV=development
DATABASE_PATH=/app/data/aquant.db
DATA_DIR=/app/data
ENABLE_PARQUET_SNAPSHOTS=true
CORS_ORIGINS=http://localhost:5173,http://localhost:8080
ENABLE_SCHEDULER=true
MARKET_UPDATE_HOUR=16
MARKET_UPDATE_MINUTE=5
SIGNAL_UPDATE_HOUR=16
SIGNAL_UPDATE_MINUTE=30
NEWS_UPDATE_HOUR=20
NEWS_UPDATE_MINUTE=30
NEWS_HISTORY_DAYS=7
RSSHUB_BASE_URL=http://rsshub:1200
RSS_UPDATE_MINUTE=15
# JSON array; leave empty to use the built-in domestic/international finance feeds.
RSS_FEEDS_JSON=
MARKET_PROVIDER=akshare
AKSHARE_SOURCE=sina
DEMO_DATA=false
AKSHARE_UNIVERSE_SIZE=0
AKSHARE_DELAY=0.35
AKSHARE_HISTORY_DAYS=500
AKSHARE_WORKERS=3
VITE_API_BASE_URL=/api

# NLP model service for deep learning sentiment analysis
MODEL_SERVICE_URL=http://localhost:8001

# Commodity Event Extraction LLM settings (SenseNova compatible OpenAI protocol)
EVENT_LLM_ENABLED=false
EVENT_LLM_BASE_URL=https://token.sensenova.cn/v1
EVENT_LLM_API_KEY=
EVENT_LLM_MODEL=sensenova-6.7-flash-lite
EVENT_LLM_TIMEOUT_SECONDS=10.0
